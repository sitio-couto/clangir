// RUN: cir-opt %s --call-conv-lowering -o %t.cir
// RUN: FileCheck %s --input-file %t.cir

!s32i = !cir.int<s, 32>
!ty_22CoercedToI6422 = !cir.struct<struct "CoercedToI64" {!cir.int<s, 32>, !cir.int<s, 32>}>
module attributes {cir.lang = #cir.lang<cxx>, cir.sob = #cir.signed_overflow_behavior<undefined>, cir.triple = "x86_64-unknown-linux-gnu", dlti.dl_spec = #dlti.dl_spec<#dlti.dl_entry<!llvm.ptr<271>, dense<32> : vector<4xi64>>, #dlti.dl_entry<!llvm.ptr<272>, dense<64> : vector<4xi64>>, #dlti.dl_entry<f128, dense<128> : vector<2xi64>>, #dlti.dl_entry<!llvm.ptr<270>, dense<32> : vector<4xi64>>, #dlti.dl_entry<f16, dense<16> : vector<2xi64>>, #dlti.dl_entry<f64, dense<64> : vector<2xi64>>, #dlti.dl_entry<i32, dense<32> : vector<2xi64>>, #dlti.dl_entry<i16, dense<16> : vector<2xi64>>, #dlti.dl_entry<i8, dense<8> : vector<2xi64>>, #dlti.dl_entry<i1, dense<8> : vector<2xi64>>, #dlti.dl_entry<!llvm.ptr, dense<64> : vector<4xi64>>, #dlti.dl_entry<f80, dense<128> : vector<2xi64>>, #dlti.dl_entry<i128, dense<128> : vector<2xi64>>, #dlti.dl_entry<i64, dense<64> : vector<2xi64>>, #dlti.dl_entry<"dlti.endianness", "little">, #dlti.dl_entry<"dlti.stack_alignment", 128 : i64>>, llvm.data_layout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"} {
  // cir.func @testCoercedToI64(%arg0: !u64i) {
  cir.func @testCoercedToI64(%arg0: !ty_22CoercedToI6422) {
    // CHECK: %0 = cir.alloca !ty_22CoercedToI6422, cir.ptr <!ty_22CoercedToI6422>, [""] {alignment = 4 : i64}
    %0 = cir.alloca !ty_22CoercedToI6422, cir.ptr <!ty_22CoercedToI6422>, ["arg", init] {alignment = 4 : i64}
    // CHECK: %1 = cir.cast(bitcast, %arg0 : !u64i), !ty_22CoercedToI6422
    // CHECK: cir.store %1, %0 : !ty_22CoercedToI6422, cir.ptr <!ty_22CoercedToI6422>
    cir.store %arg0, %0 : !ty_22CoercedToI6422, cir.ptr <!ty_22CoercedToI6422>
    cir.return
  }
}
