// RUN: cir-opt %s --call-conv-lowering -o %t.cir
// RUN: FileCheck %s --input-file %t.cir

!s8i = !cir.int<s, 8>
!s16i = !cir.int<s, 16>
!s32i = !cir.int<s, 32>
!s64i = !cir.int<s, 64>
!u8i = !cir.int<u, 8>
!u16i = !cir.int<u, 16>
!u32i = !cir.int<u, 32>
!u64i = !cir.int<u, 64>

!StructToI64 = !cir.struct<struct "StructToI64" {!cir.int<s, 32>, !cir.int<s, 32>}>

// Set triple and data layout to X86-64.
module attributes {cir.lang = #cir.lang<cxx>, cir.sob = #cir.signed_overflow_behavior<undefined>, cir.triple = "x86_64-unknown-linux-gnu", dlti.dl_spec = #dlti.dl_spec<#dlti.dl_entry<!llvm.ptr<271>, dense<32> : vector<4xi64>>, #dlti.dl_entry<!llvm.ptr<272>, dense<64> : vector<4xi64>>, #dlti.dl_entry<f128, dense<128> : vector<2xi64>>, #dlti.dl_entry<!llvm.ptr<270>, dense<32> : vector<4xi64>>, #dlti.dl_entry<f16, dense<16> : vector<2xi64>>, #dlti.dl_entry<f64, dense<64> : vector<2xi64>>, #dlti.dl_entry<i32, dense<32> : vector<2xi64>>, #dlti.dl_entry<i16, dense<16> : vector<2xi64>>, #dlti.dl_entry<i8, dense<8> : vector<2xi64>>, #dlti.dl_entry<i1, dense<8> : vector<2xi64>>, #dlti.dl_entry<!llvm.ptr, dense<64> : vector<4xi64>>, #dlti.dl_entry<f80, dense<128> : vector<2xi64>>, #dlti.dl_entry<i128, dense<128> : vector<2xi64>>, #dlti.dl_entry<i64, dense<64> : vector<2xi64>>, #dlti.dl_entry<"dlti.endianness", "little">, #dlti.dl_entry<"dlti.stack_alignment", 128 : i64>>, llvm.data_layout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"} {

//===----------------------------------------------------------------------===//
// Test trivial function call and definition call conv lowering scenarios.
//===----------------------------------------------------------------------===//

  // CHECK: @Void() {
  cir.func @Void() {
    cir.call @Void() : () -> ()
    cir.return
  }

  // TODO(cir): Missing noundef attributes in some cases.
  // TODO(cir): Calls do not have return and argument attributes.

  // CHECK: @UChar(%arg0: !u8i {cir.zeroext}) -> (!u8i {cir.zeroext}) {
  cir.func @UChar(%arg0: !u8i) -> !u8i {
    %0 = cir.call @UChar(%arg0) : (!u8i) -> !u8i
    cir.return %0 : !u8i
  }

  // CHECK: @UShort(%arg0: !u16i  {cir.zeroext}) -> (!u16i {cir.zeroext}) {
  cir.func @UShort(%arg0: !u16i) -> !u16i {
    %0 = cir.call @UShort(%arg0) : (!u16i) -> !u16i
    cir.return %0 : !u16i
  }

  // CHECK: @UInt(%arg0: !u32i) -> !u32i {
  cir.func @UInt(%arg0: !u32i) -> !u32i {
    %0 = cir.call @UInt(%arg0) : (!u32i) -> !u32i
    cir.return %0 : !u32i 
  }

  // CHECK: @ULong(%arg0: !u64i) -> !u64i {
  cir.func @ULong(%arg0: !u64i) -> !u64i {
    %0 = cir.call @ULong(%arg0) : (!u64i) -> !u64i
    cir.return %0 : !u64i
  }

  // CHECK: @SChar(%arg0: !s8i {cir.signext}) -> (!s8i {cir.signext}) {
  cir.func @SChar(%arg0: !s8i) -> !s8i {
    %0 = cir.call @SChar(%arg0) : (!s8i) -> !s8i
    cir.return %0 : !s8i
  }

  // CHECK: @SShort(%arg0: !s16i {cir.signext}) -> (!s16i {cir.signext}) {
  cir.func @SShort(%arg0: !s16i) -> !s16i {
    %0 = cir.call @SShort(%arg0) : (!s16i) -> !s16i
    cir.return %0 : !s16i
  }

  // CHECK: @SInt(%arg0: !s32i) -> !s32i {
  cir.func @SInt(%arg0: !s32i) -> !s32i {
    %0 = cir.call @SInt(%arg0) : (!s32i) -> !s32i
    cir.return %0 : !s32i
  }

  // CHECK: @SLong(%arg0: !s64i) -> !s64i {
  cir.func @SLong(%arg0: !s64i) -> !s64i {
    %0 = cir.call @SLong(%arg0) : (!s64i) -> !s64i
    cir.return %0 : !s64i
  }

  // FIXME(cir): Is !cir.float truly ABI-specific? If not, it should be converted to !f32.
  // CHECK: @Float(%arg0: !cir.float) -> !cir.float {
  cir.func @Float(%arg0: !cir.float) -> !cir.float {
    %0 = cir.call @Float(%arg0) : (!cir.float) -> !cir.float
    cir.return %0 : !cir.float
  }

  // FIXME(cir): Is !cir.double truly ABI-specific? If not, it should be converted to !f64.
  // CHECK: @Double(%arg0: !cir.double) -> !cir.double {
  cir.func @Double(%arg0: !cir.double) -> !cir.double {
    %0 = cir.call @Double(%arg0) : (!cir.double) -> !cir.double
    cir.return %0 : !cir.double
  }

  // NOTE(cir): Since we have a ABI-agnostic representation for bool, it requires
  // a bit more work to lower it than the other trivial cases which are already
  // lowered as ABI-speicifc types, albeit without attributes.

  // CHECK: @Bool(%arg0: !cir.int<u, 1> {cir.zeroext}) -> (!cir.int<u, 1> {cir.zeroext}) {
  cir.func @Bool(%arg0: !cir.bool) -> !cir.bool {
    // CHECK: %[[#V0:]] = cir.alloca !cir.bool, !cir.ptr<!cir.bool>
    // CHECK: %[[#V1:]] = cir.cast(bitcast, %arg0 : !cir.int<u, 1>), !cir.bool
    // CHECK: cir.store %[[#V1]], %[[#V0]] : !cir.bool, !cir.ptr<!cir.bool>
    %0 = cir.alloca !cir.bool, !cir.ptr<!cir.bool>, ["arg", init] {alignment = 1 : i64}
    %1 = cir.alloca !cir.bool, !cir.ptr<!cir.bool>, ["__retval"] {alignment = 1 : i64}
    cir.store %arg0, %0 : !cir.bool, !cir.ptr<!cir.bool>
    %2 = cir.load %0 : !cir.ptr<!cir.bool>, !cir.bool
    // CHECK: %[[#V4:]] = cir.cast(bitcast, %{{.+}} : !cir.bool), !cir.int<u, 1>
    // CHECK: %[[#V5:]] = cir.call @Bool(%[[#V4]]) : (!cir.int<u, 1>) -> !cir.int<u, 1>
    // CHECK: %{{.+}} = cir.cast(bitcast, %[[#V5]] : !cir.int<u, 1>), !cir.bool
    %3 = cir.call @Bool(%2) : (!cir.bool) -> !cir.bool
    cir.store %3, %1 : !cir.bool, !cir.ptr<!cir.bool>
    %4 = cir.load %1 : !cir.ptr<!cir.bool>, !cir.bool
    // CHECK: %[[#V5:]] = cir.cast(bitcast, %{{.+}} : !cir.bool), !cir.int<u, 1>
    // CHECK: cir.return %[[#V5]] : !cir.int<u, 1>
    cir.return %4 : !cir.bool
  }

  // TODO(cir): Support pointer types.

  // cir.func @Ptr(%arg0: !cir.ptr<!s32i>) -> !cir.ptr<!s32i> {
  //   cir.return %arg0 : !cir.ptr<!s32i>
  // }


//===----------------------------------------------------------------------===//
// Test calling convention struct types coercion.
//
// These test validate arguments and return values that consist of structs are
// properly casted to ABI-specific types in function definitions and calls.
//===----------------------------------------------------------------------===//

  // CHECK: cir.func @coerceStructToI64(%arg0: !u64i) -> !u64i {
  cir.func @coerceStructToI64(%arg0: !StructToI64) -> !StructToI64 {
    // CHECK: %[[#V0:]] = cir.alloca !ty_22StructToI6422, !cir.ptr<!ty_22StructToI6422>
    // CHECK: %[[#V1:]] = cir.cast(bitcast, %arg0 : !u64i), !ty_22StructToI6422
    // CHECK: cir.store %[[#V1]], %[[#V0]] : !ty_22StructToI6422, !cir.ptr<!ty_22StructToI6422>
    %0 = cir.alloca !StructToI64, !cir.ptr<!StructToI64>, ["arg", init] {alignment = 4 : i64}
    %1 = cir.alloca !StructToI64, !cir.ptr<!StructToI64>, ["__retval"] {alignment = 4 : i64}
    %2 = cir.alloca !StructToI64, !cir.ptr<!StructToI64>, ["agg.tmp0"] {alignment = 4 : i64}
    cir.store %arg0, %0 : !StructToI64, !cir.ptr<!StructToI64>
    %3 = cir.load %2 : !cir.ptr<!StructToI64>, !StructToI64
    // CHECK: %[[#V5:]] = cir.cast(bitcast, %{{.+}} : !ty_22StructToI6422), !u64i
    // CHECK: %[[#V6:]] = cir.call @coerceStructToI64(%[[#V5]]) : (!u64i) -> !u64i
    // CHECK: %{{.+}} = cir.cast(bitcast, %[[#V6]] : !u64i), !ty_22StructToI6422
    %4 = cir.call @coerceStructToI64(%3) : (!StructToI64) -> !StructToI64
    cir.store %4, %1 : !StructToI64, !cir.ptr<!StructToI64>
    %5 = cir.load %1 : !cir.ptr<!StructToI64>, !StructToI64
    // CHECK: %[[#V9:]] = cir.cast(bitcast, %{{.+}} : !ty_22StructToI6422), !u64i
    // CHECK: cir.return %[[#V9]] : !u64i
    cir.return %5 : !StructToI64
  }

} // module.
