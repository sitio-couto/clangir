// RUN: cir-opt %s --call-conv-lowering -o %t.cir
// RUN: FileCheck %s --input-file %t.cir

!s8i = !cir.int<s, 8>
!s16i = !cir.int<s, 16>
!s32i = !cir.int<s, 32>
!s64i = !cir.int<s, 64>
!u8i = !cir.int<u, 8>
!u16i = !cir.int<u, 16>
!u32i = !cir.int<u, 32>
!u64i = !cir.int<u, 64>

!ty_22CoerceToI6422 = !cir.struct<struct "CoerceToI64" {!cir.int<s, 32>, !cir.int<s, 32>}>

// Set triple and data layout to X86-64.
module attributes {cir.lang = #cir.lang<cxx>, cir.sob = #cir.signed_overflow_behavior<undefined>, cir.triple = "x86_64-unknown-linux-gnu", dlti.dl_spec = #dlti.dl_spec<#dlti.dl_entry<!llvm.ptr<271>, dense<32> : vector<4xi64>>, #dlti.dl_entry<!llvm.ptr<272>, dense<64> : vector<4xi64>>, #dlti.dl_entry<f128, dense<128> : vector<2xi64>>, #dlti.dl_entry<!llvm.ptr<270>, dense<32> : vector<4xi64>>, #dlti.dl_entry<f16, dense<16> : vector<2xi64>>, #dlti.dl_entry<f64, dense<64> : vector<2xi64>>, #dlti.dl_entry<i32, dense<32> : vector<2xi64>>, #dlti.dl_entry<i16, dense<16> : vector<2xi64>>, #dlti.dl_entry<i8, dense<8> : vector<2xi64>>, #dlti.dl_entry<i1, dense<8> : vector<2xi64>>, #dlti.dl_entry<!llvm.ptr, dense<64> : vector<4xi64>>, #dlti.dl_entry<f80, dense<128> : vector<2xi64>>, #dlti.dl_entry<i128, dense<128> : vector<2xi64>>, #dlti.dl_entry<i64, dense<64> : vector<2xi64>>, #dlti.dl_entry<"dlti.endianness", "little">, #dlti.dl_entry<"dlti.stack_alignment", 128 : i64>>, llvm.data_layout = "e-m:e-p270:32:32-p271:32:32-p272:64:64-i64:64-i128:128-f80:128-n8:16:32:64-S128"} {

//===----------------------------------------------------------------------===//
// Test trivial call conv lowering scenarios.
//===----------------------------------------------------------------------===//

  // CHECK: func @Void()
  cir.func @Void() {
    cir.return
  }

  // TODO(cir): Missing noundef attributes in some of the following tests.
  // TODO(cir): Signedness of the integer types is not being preserved.

  // CHECK: @UChar(%arg0: !u8i {cir.zeroext}) -> (!u8i {cir.zeroext})
  cir.func @UChar(%arg0: !u8i) -> !u8i {
    cir.return %arg0 : !u8i
  }

  // CHECK: cir.func @UShort(%arg0: !u16i  {cir.zeroext}) -> (!u16i {cir.zeroext})
  cir.func @UShort(%arg0: !u16i) -> !u16i {
    cir.return %arg0 : !u16i
  }

  // CHECK: cir.func @UInt(%arg0: !u32i) -> !u32i
  cir.func @UInt(%arg0: !u32i) -> !u32i {
    cir.return %arg0 : !u32i
  }

  // CHECK: cir.func @ULong(%arg0: !u64i) -> !u64i
  cir.func @ULong(%arg0: !u64i) -> !u64i {
    cir.return %arg0 : !u64i
  }

  // CHECK: cir.func @SChar(%arg0: !s8i {cir.signext}) -> (!s8i {cir.signext})
  cir.func @SChar(%arg0: !s8i) -> !s8i {
    cir.return %arg0 : !s8i
  }

  // CHECK: cir.func @SShort(%arg0: !s16i {cir.signext}) -> (!s16i {cir.signext})
  cir.func @SShort(%arg0: !s16i) -> !s16i {
    cir.return %arg0 : !s16i
  }

  // CHECK: cir.func @SInt(%arg0: !s32i) -> !s32i
  cir.func @SInt(%arg0: !s32i) -> !s32i {
    cir.return %arg0 : !s32i
  }

  // CHECK: cir.func @SLong(%arg0: !s64i) -> !s64i
  cir.func @SLong(%arg0: !s64i) -> !s64i {
    cir.return %arg0 : !s64i
  }

  // TODO(cir): Floating point types.

  // CHECK: cir.func @Float(%arg0: f32) -> f32
  cir.func @Float(%arg0: f32) -> f32 {
    cir.return %arg0 : f32
  }

  // CHECK: cir.func @Double(%arg0: f64) -> f64
  cir.func @Double(%arg0: f64) -> f64 {
    cir.return %arg0 : f64
  }

  // // CHECK: cir.func @Bool(%arg0: !cir.bool) -> !cir.bool
  // cir.func @Bool(%arg0: !cir.bool) -> !cir.bool {
  //   cir.return %arg0 : !cir.bool
  // }

  // TODO(cir): Support pointer types.

  // // CHECK: cir.func @Ptr(%arg0: !cir.ptr<!s32i>) -> !cir.ptr<!s32i>
  // cir.func @Ptr(%arg0: !cir.ptr<!s32i>) -> !cir.ptr<!s32i> {
  //   cir.return %arg0 : !cir.ptr<!s32i>
  // }

  // TODO(cir): Support struct types coercion.

  // cir.func @coerceStructToI64(%arg0: !u64i) {
  cir.func @coerceStructToI64(%arg0: !ty_22CoerceToI6422) {
    // CHECK: %0 = cir.alloca !ty_22CoerceToI6422, cir.ptr <!ty_22CoerceToI6422>, [""] {alignment = 4 : i64}
    %0 = cir.alloca !ty_22CoerceToI6422, cir.ptr <!ty_22CoerceToI6422>, ["arg", init] {alignment = 4 : i64}
    // CHECK: %1 = cir.cast(bitcast, %arg0 : !u64i), !ty_22CoerceToI6422
    // CHECK: cir.store %1, %0 : !ty_22CoerceToI6422, cir.ptr <!ty_22CoerceToI6422>
    cir.store %arg0, %0 : !ty_22CoerceToI6422, cir.ptr <!ty_22CoerceToI6422>
    cir.return
  }

} // module.
